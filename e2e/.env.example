# Copy to .env and adjust (see README in repo root → E2E tests).
# Playwright loads this file automatically when you run tests from e2e/.

# Optional: game server HTTP base URL for tests/backend-health.spec.ts
# Use 127.0.0.1 (not localhost) to avoid IPv6 ::1 connection issues on some setups.
# Backend must be running: cd ../backend && npm run start:dev
E2E_BACKEND_URL=http://127.0.0.1:2567
